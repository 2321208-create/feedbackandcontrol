
Prob 1
import control as ctrl
import matplotlib.pyplot as plt

num1 = [1]        
den1 = [1, 2, 2]

G = ctrl.tf(num1, den1)
print(G)
<TransferFunction>: sys[2]
Inputs (1): ['u[0]']
Outputs (1): ['y[0]']

        1
  -------------
  s^2 + 2 s + 2
poles1 = ctrl.poles(G)
print("No. 1 Poles: ", poles1)
No. 1 Poles:  [-1.+1.j -1.-1.j]
zeroes1 = ctrl.zeros(G)
print("No. 1 Zeroes: ", zeroes1)
No. 1 Zeroes:  []
ctrl.pzmap(G, grid=True)
plt.show()

