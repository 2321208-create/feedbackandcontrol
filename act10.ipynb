import os
from openai import OpenAI

# 1. Setup the client to point to LM Studio's local server
# Default port is 1234
client = OpenAI(base_url="http://localhost:1234/v1", api_key="lm-studio")

MODEL_NAME = "local-model"

# 2. CUSTOM PERSONALITY
# Modify the content below to change how the AI acts and responds
system_prompt = """You are 'Nova', a highly intelligent, witty, and slightly sarcastic AI assistant. 
You give clear and accurate answers, but you always add a bit of dry humor. You are currently running locally on the user's machine."""

# Initialize chat history with the system prompt
chat_history = [
    {"role": "system", "content": system_prompt}
]

print("Connecting to LM Studio... (Make sure the Local Server is running!)")
print("-" * 65)
print("Commands:")
print("  Type 'exit' to quit.")
print("  Type '/read <filename.txt>' to let the AI read a local text file.")
print("-" * 65)

while True:
    try:
        # Get user input
        query = input("\nEnter your message: ").strip()
        
        # Exit condition
        if query.lower() == "exit":
            print("\nNova: See you later! Try not to break anything while I'm gone.")
            print("Exiting...")
            break
            
        if not query:
            continue
            
        # 3. LOCAL FILE ACCESS
        # Check if the user is using the /read command
        if query.startswith("/read "):
            filename = query[6:].strip() # Extract everything after "/read "
            
            # Check if the file exists on the user's computer
            if os.path.exists(filename):
                with open(filename, 'r', encoding='utf-8') as file:
                    file_content = file.read()
                
                # Inject the file content into the AI's memory as a system note
                file_context = f"System Note: The user has uploaded a file named '{filename}'. Here is the text inside it:\n\n{file_content}"
                chat_history.append({"role": "system", "content": file_context})
                
                print(f"\n[System: Successfully loaded '{filename}' into Nova's memory. You can now ask questions about it!]")
                continue # Skip asking the AI to reply until the user asks a real question
            else:
                print(f"\n[System Error: Could not find '{filename}'. Make sure it is in the same folder as this Python script.]")
                continue

        print(f"\nUser: {query}")
        print("-+" * 50)
        
        # Save user message to history
        chat_history.append({"role": "user", "content": query})
        
        # Stream AI response
        stream = client.chat.completions.create(
            model=MODEL_NAME,
            messages=chat_history,
            temperature=0.7,
            stream=True
        )
        
        full_ai_response = ""
        print("Nova: ", end="", flush=True)
        
        # Read the stream chunk by chunk
        for chunk in stream:
            delta = getattr(chunk.choices[0].delta, "content", None)
            if delta:
                print(delta, end="", flush=True)
                full_ai_response += delta
                
        print()
        
        # Save AI response to history so it remembers the conversation context
        chat_history.append({"role": "assistant", "content": full_ai_response})
        
        print("*/" * 50)
        
    except KeyboardInterrupt:
        # Handles the user pressing Ctrl+C gracefully
        print("\n\nNova: Interrupt received. Shutting down gracefully...")
        break
    except Exception as e:
        print(f"\nAn error occurred: {e}")
        print("Please check that your LM Studio server is running on http://localhost:1234/v1")
        break
